# ── Anthropic (análise de mercado) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── Binance ─────────────────────────────────────────────────────
# Demo: chaves da testnet (https://testnet.binance.vision)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
# Real: chaves da conta de verdade (só preencha quando for ao modo live)
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# ── Alpaca ──────────────────────────────────────────────────────
# Demo: chaves de paper trading (https://alpaca.markets)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
# Real: chaves da conta de verdade (só preencha quando for ao modo live)
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# ── Trava de segurança do modo real ─────────────────────────────
# Para operar com dinheiro real, além de mode: live no config.yaml,
# esta variável PRECISA estar definida exatamente assim:
# PHEBOS_CONFIRM_LIVE=EU_ACEITO_O_RISCO
PHEBOS_CONFIRM_LIVE=
